#!/bin/sh
#
# pre-push — 重ゲート（ツール非依存・全プッシャーに強制）
#
# 強制ゲートは Git ネイティブフックに集約する（ADR 0005-git-hooks-over-claude-hooks）。
# Claude / Codex / 素の git / CI すべてに効く。`core.hooksPath=.githooks` は
# package.json の `prepare` スクリプト（Phase 5）で設定される。
#
# push 境界に重い検証（テスト + カバレッジ100%）を集約する。コミットは軽く保ち、
# ループ速度を落とさない（編集毎の全テスト実行は不採用）。

set -e

echo "[pre-push] pnpm test:cov"
pnpm test:cov

# pokeform パーティ検証ゲート（Phase 2）: 妥当なサンプルパーティ全体（メンバー個体含む）を
# codegen→tsc で end-to-end 検証する。broken.md は不正検出デモのため対象外（standard.md のみ）。
echo "[pre-push] pokeform typecheck team/parties/standard.md"
pnpm pokeform typecheck team/parties/standard.md

echo "[pre-push] OK"
