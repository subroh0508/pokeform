#!/bin/sh
#
# pre-commit — 高速ゲート（ツール非依存・全コミッターに強制）
#
# 強制ゲートは Git ネイティブフックに集約する（ADR 0005-git-hooks-over-claude-hooks）。
# これは Claude / Codex / 素の git / CI すべてに効く。`core.hooksPath=.githooks` は
# package.json の `prepare` スクリプト（Phase 5）で設定され、新規 clone でも
# `pnpm install` で自動有効化される。
#
# コミット境界は「軽く」保つ: ここでは型チェック・Lint・サンプル個体の tsc 検証のみ。
# 重い検証（テスト・カバレッジ）は pre-push へ集約する。

set -e

echo "[pre-commit] pnpm typecheck"
pnpm typecheck

echo "[pre-commit] pnpm lint"
pnpm lint

# pokeform 個体検証ゲート（Phase 2）: サンプル個体 YAML を codegen→tsc で検証する。
# team/individuals は全て妥当な個体のみ（不正デモは team/parties/broken.md・意図的に対象外）。
echo "[pre-commit] pokeform check:individual team/individuals"
pnpm pokeform check:individual team/individuals

# pokeform レギュレーション検証ゲート（02 Phase 6・ADR 0023）: regulation YAML の参照整合 / schema /
# 覚えない技を authoring 時に検証する。覚えない技検証は data/raw（learnset）が要り、未取得時は参照整合
# のみに degrade する（full 検証は pnpm fetch:data 後・CI はオフライン維持で本ゲートを課さない）。
echo "[pre-commit] pokeform check:regulation data/champions/regulations"
pnpm pokeform check:regulation data/champions/regulations

echo "[pre-commit] OK"
