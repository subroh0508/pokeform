{
  "name": "pokeform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome check --write .",
    "verify": "pnpm typecheck && pnpm test:cov && pnpm lint",
    "gen:rules-index": "node scripts/gen-rules-index.ts",
    "prepare": "git config core.hooksPath .githooks && node scripts/gen-rules-index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitest/coverage-v8": "4.1.8",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
